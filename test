# Source: vaultwarden/templates/deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: release-name-vaultwarden
  labels:
    helm.sh/chart: vaultwarden-0.1.0
    app.kubernetes.io/name: vaultwarden
    app.kubernetes.io/instance: release-name
    app.kubernetes.io/version: "1.16.0"
    app.kubernetes.io/managed-by: Helm
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: vaultwarden
      app.kubernetes.io/instance: release-name
  template:
    metadata:
      labels:
        helm.sh/chart: vaultwarden-0.1.0
        app.kubernetes.io/name: vaultwarden
        app.kubernetes.io/instance: release-name
        app.kubernetes.io/version: "1.16.0"
        app.kubernetes.io/managed-by: Helm
    spec:
      serviceAccountName: release-name-vaultwarden
      containers:
        - name: vaultwarden
          image: "ghcr.io/jack-lull/vaultwarden:c5996e6dad26897fbe985046f1d5a897557cbcfb"
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: 80
              protocol: TCP
          livenessProbe:
            httpGet:
              path: /
              port: http
          readinessProbe:
            httpGet:
              path: /
              port: http
          env:
            - name: ADMIN_TOKEN
              value: "qwerty123"
            - name: DOMAIN
              value: "https://example.net"
            - name: SIGNUPS_ALLOWED
              value: "true"
            - name: SIGNUPS_VERIFY
              value: "false"
            - name: WEB_VAULT_ENABLED
              value: "true"
            - name: DATABASE_URL
              valueFrom:
                secretKeyRef:
                  name: db-creds
                  key: DATABASE_URL
---
# Source: vaultwarden/templates/database.yaml
apiVersion: kinda.rocks/v1beta1
kind: Database
metadata:
  name: release-name-vaultwarden
  labels:
    helm.sh/chart: vaultwarden-0.1.0
    app.kubernetes.io/name: vaultwarden
    app.kubernetes.io/instance: release-name
    app.kubernetes.io/version: "1.16.0"
    app.kubernetes.io/managed-by: Helm
spec:
  secretName: db-creds
  instance: postgres
  deletionProtected:
  credentials:
    templates:
      - name: DATABASE_URL
        template: "{{ .Protocol }}://{{ .Username }}:{{ .Password }}@{{ .Hostname }}:{{ .Port }}/{{ .Database }}"
        secret: true
